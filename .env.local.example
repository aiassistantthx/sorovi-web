# Sanity CMS Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-12-15
SANITY_API_TOKEN=your_sanity_token_here

# OpenAI API (for content translation)
OPENAI_API_KEY=your_openai_api_key_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://sorovi.ai
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/sorovi
NEXT_PUBLIC_GOOGLE_PLAY_URL=https://play.google.com/store/apps/details?id=ai.sorovi

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id_here

# Environment
NODE_ENV=development
